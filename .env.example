# WhisClaw Configuration
LLM_SERVER=picoclaw

# WhisClaw specific
WHISCLAW_BACKEND=picoclaw
WHISCLAW_BRIDGE_PATH=/home/pi/whisclaw-bridge/whisclaw-ask.sh
WHISCLAW_TIMEOUT_MS=45000

# LLM Provider (MiniMax example)
MINIMAX_API_KEY=your_key_here
MINIMAX_LLM_MODEL=MiniMax-M2.7
MINIMAX_API_URL=https://api.minimax.io/v1/chat/completions

# Whisplay hardware
WHISPLAY_IM_BRIDGE_HOST=127.0.0.1
WHISPLAY_IM_BRIDGE_PORT=18888
